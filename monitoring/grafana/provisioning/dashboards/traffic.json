{
  "title": "Traffic CV — Overview",
  "uid": "traffic-cv",
  "description": "Συνολική εικόνα του pipeline: ταχύτητες, οχήματα, παραβάσεις και latency επεξεργασίας.",
  "tags": ["traffic", "overview"],
  "version": 3,
  "schemaVersion": 36,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Avg Speed per Stream per 5min (Q7)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "velocitykmh",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -45,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg by (stream, window) (avg_speed_kmh_per_stream_per_window)",
          "legendFormat": "{{stream}} — {{window}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Vehicle Count per Stream per 5min (Q5)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -45,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (stream, window) (vehicles_per_stream_per_window)",
          "legendFormat": "{{stream}} — {{window}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Truck % per Stream (Q2)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg by (stream) (truck_percentage_per_stream)",
          "legendFormat": "{{stream}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Speed Violations (Q3)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(speed_violations_total)",
          "legendFormat": "Violations"
        }
      ]
    },
    {
      "id": 5,
      "title": "Trucks Outside Far-Left Lane (Q8)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(trucks_not_far_left_total)",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 6,
      "title": "Clip Processing Latency — Histogram (CV Worker)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "hidden" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (cv_chunk_processing_seconds_bucket)",
          "legendFormat": "≤{{le}}s",
          "instant": true
        }
      ]
    }
  ]
}
