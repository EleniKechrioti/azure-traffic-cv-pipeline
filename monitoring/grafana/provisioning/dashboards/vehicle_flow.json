{
  "title": "Traffic CV — Vehicle Flow",
  "uid": "traffic-flow",
  "version": 1,
  "schemaVersion": 36,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Vehicles (All Streams)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(vehicles_per_stream_per_window{job=\"analytics_all\"})",
          "legendFormat": "Total"
        }
      ]
    },
    {
      "id": 2,
      "title": "Avg Truck %",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg(truck_percentage_per_stream{job=\"analytics_all\"})",
          "legendFormat": "Avg Truck %"
        }
      ]
    },
    {
      "id": 3,
      "title": "Vehicles per Stream (Latest)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 100 },
              { "color": "yellow", "value": 300 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (stream) (vehicles_per_stream_per_window{job=\"analytics_all\"})",
          "legendFormat": "{{stream}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Vehicle Count per Stream per 5min (Q5)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -45,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (stream, window) (vehicles_per_stream_per_window{job=\"analytics_all\"})",
          "legendFormat": "{{stream}} — {{window}}",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Truck % per Stream per Window (Q2)",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "color": { "mode": "palette-classic" },
          "custom": { "fillOpacity": 80, "lineWidth": 0 }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -45,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg by (stream) (truck_percentage_per_stream{job=\"analytics_all\"})",
          "legendFormat": "{{stream}}",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Truck % by Stream (Latest)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 20,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "orientation": "vertical",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "avg by (stream) (truck_percentage_per_stream{job=\"analytics_all\"})",
          "legendFormat": "{{stream}}"
        }
      ]
    }
  ]
}
