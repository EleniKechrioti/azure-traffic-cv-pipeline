        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(vehicles_per_stream_per_window)",
          "legendFormat": "Vehicles"
        }
      ]
    },
    {
      "id": 5,
      "title": "Processing Latency Over Time (p50 / p95 / p99)",
      "type": "barchart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": 0,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.50, rate(cv_chunk_processing_seconds_bucket[5m]))",
          "legendFormat": "p50",
          "instant": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(cv_chunk_processing_seconds_bucket[5m]))",
          "legendFormat": "p95",
          "instant": true
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "histogram_quantile(0.99, rate(cv_chunk_processing_seconds_bucket[5m]))",
          "legendFormat": "p99",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Vehicle Count per Stream Over Time (Q5)",
      "type": "barchart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 14,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 80,
            "lineWidth": 0
          }
        }
      },
      "options": {
        "orientation": "vertical",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "xTickLabelRotation": -45,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (stream) (vehicles_per_stream_per_window)",
          "legendFormat": "{{stream}}",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
